# Purpose:
# - Nuke Group node that runs OpenAI GPT Image 2 edit (fal.ai) on reference image(s) and creates Read node(s).
# - Keeps the .nk execute script small by delegating logic to a Python runner in `nuke/python/`.

set cut_paste_input [stack 0]
version 11.3 v6
push $cut_paste_input
Group {
 name GPT_Image_2_Edit_v1
 selected true
 xpos -340
 ypos 120
 addUserKnob {20 Settings}
 addUserKnob {1 prompt l Prompt}
 prompt "Describe the edit you want (or connect a Text node with a message knob to override)"
 addUserKnob {1 num_images l "Num images (1-4)"}
 num_images "1"
 addUserKnob {1 image_size l "Image size"}
 image_size auto
 addUserKnob {4 quality l Quality M {auto low medium high ""}}
 quality high
 addUserKnob {4 output_format l "Output format" M {png jpeg webp ""}}
 output_format png
 addUserKnob {6 show_success_popup l "Show success popup" +STARTLINE}
 show_success_popup true
 addUserKnob {22 execute T "import _nuke_runner_launcher\n_nuke_runner_launcher.execute_this_node()\n" +STARTLINE}
 addUserKnob {20 endGroup n -1}
 addUserKnob {1 python3_cmd l "Python 3 cmd" +INVISIBLE}
 python3_cmd "py -3"
 addUserKnob {1 helper_path l "Helper path" +INVISIBLE}
 helper_path "__INSTALL_ROOT__/nuke/python/fal_gpt_image_2_edit_helper.py"
 addUserKnob {1 runner_path l "Runner path" +INVISIBLE}
 runner_path "__INSTALL_ROOT__/nuke/python/fal_gpt_image_2_edit_runner_v1.py"
 addUserKnob {1 FAL +INVISIBLE}
 FAL "insert your secret key here or use env variable FAL_KEY"
}
Text {
 inputs 0
 message "Input 0: optional Text node (has a 'message' knob) to override Prompt.\\nInput 1-2: reference images (at least one required). Input 3: optional mask.\\nThen press execute."
 font C:/Windows/Fonts/arial.ttf
 yjustify bottom
 Transform 1
 box {30 30 1906 1052}
 center {560 372}
 name Text1
 xpos 96
 ypos 301
}
set N0e5f49c0 [stack 0]
Output {
 name Output1
 xpos 96
 ypos 409
}
Input {
 inputs 0
 name prompt_text
 xpos 0
 ypos -51
}
Input {
 inputs 0
 name ref_image_a
 xpos 120
 ypos -51
}
Input {
 inputs 0
 name ref_image_b
 xpos 240
 ypos -51
}
Input {
 inputs 0
 name mask
 xpos 360
 ypos -51
}
push $N0e5f49c0
Viewer {
 inputs 1
 frame_range 0-199
 fps 25
 input_number 0
 name Viewer1
 selected true
 xpos 396
 ypos 412
}
end_group
