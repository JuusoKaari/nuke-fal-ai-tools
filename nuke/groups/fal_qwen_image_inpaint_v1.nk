# Purpose:
# - Nuke Group node that runs fal.ai Qwen Image Edit *inpainting* on a still plate + mask and creates Read node(s).
# - Model: https://fal.ai/models/fal-ai/qwen-image-edit/inpaint
# - White (high) in the mask = region to repaint; black keeps the original plate.

set cut_paste_input [stack 0]
version 11.3 v6
push $cut_paste_input
Group {
 name Qwen_Image_Edit_Inpaint_v1
 selected true
 xpos -331
 ypos 7
 addUserKnob {20 Settings}
 addUserKnob {1 prompt l Prompt}
 prompt "Describe what should appear inside the masked region"
 addUserKnob {1 negative_prompt l "Negative prompt"}
 negative_prompt ""
 addUserKnob {4 output_format l "Output format" M {png jpeg ""}}
 output_format png
 addUserKnob {1 num_images l "Num images (1-4)"}
 num_images "1"
 addUserKnob {1 num_inference_steps l Steps}
 num_inference_steps "30"
 addUserKnob {1 guidance_scale l "Guidance scale"}
 guidance_scale "4"
 addUserKnob {1 strength l Strength}
 strength "0.93"
 addUserKnob {4 acceleration l Acceleration M {none regular high}}
 acceleration regular
 addUserKnob {6 enable_safety_checker l "Enable safety checker" +STARTLINE}
 enable_safety_checker true
 addUserKnob {6 show_success_popup l "Show success popup" +STARTLINE}
 show_success_popup true
 addUserKnob {1 seed l "Seed (optional)"}
 seed ""
 addUserKnob {1 image_size l "Image size (optional)"}
 image_size ""
 addUserKnob {22 execute T "import _nuke_runner_launcher\n_nuke_runner_launcher.execute_this_node()\n" +STARTLINE}
 addUserKnob {20 endGroup n -1}
 addUserKnob {1 python3_cmd l "Python 3 cmd" +INVISIBLE}
 python3_cmd "py -3"
 addUserKnob {1 helper_path l "Helper path" +INVISIBLE}
 helper_path "__INSTALL_ROOT__/nuke/python/fal_qwen_image_inpaint_helper.py"
 addUserKnob {1 runner_path l "Runner path" +INVISIBLE}
 runner_path "__INSTALL_ROOT__/nuke/python/fal_qwen_image_inpaint_runner_v1.py"
 addUserKnob {1 FAL +INVISIBLE}
 FAL "insert your secret key here or use env variable FAL_KEY"
}
Text {
 inputs 0
 message "Connect source_image (input 0) and mask (input 1).\nWhite in mask = inpaint region. Set prompt, then Execute."
 font C:/Windows/Fonts/arial.ttf
 yjustify bottom
 Transform 1
 box {30 30 1906 1052}
 center {560 372}
 name Text1
 xpos 101
 ypos 294
}
set NqwInpaint0 [stack 0]
Output {
 name Output1
 xpos 101
 ypos 406
}
Input {
 inputs 0
 name source_image
 xpos 0
 ypos -51
}
Input {
 inputs 0
 name mask
 xpos 188
 ypos -51
 number 1
}
push $NqwInpaint0
Viewer {
 inputs 1
 frame_range 0-199
 fps 25
 input_number 0
 name Viewer1
 selected true
 xpos 281
 ypos 412
}
end_group
